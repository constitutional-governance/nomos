GOVERNANCE_MODE=local
GOVERNANCE_REPO_PATH=/path/to/your-governance-repo

# github mode — uncomment when the governance repo is on GitHub
# GOVERNANCE_MODE=github
# GOVERNANCE_REPO_URL=https://github.com/your-org/your-governance-repo
# GITHUB_TOKEN=ghp_...
# CACHE_TTL_SECONDS=300

AUTH_ENABLED=false
MCP_SERVER_PORT=8080
LOG_LEVEL=INFO
